{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // Node types for the Node-side test toolchain (e.g. reading app.css from disk in
    // the class-vs-CSS drift test). The browser `src` uses the DOM `lib` above; the
    // adaptive `ReturnType<typeof setTimeout>` keeps timer types correct under both.
    "types": ["node"],
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  // app.js is now an esbuild-generated bundle (built from src/), not hand-source — it is not
  // type-checked here; the real TypeScript under src/ + test/ is.
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
